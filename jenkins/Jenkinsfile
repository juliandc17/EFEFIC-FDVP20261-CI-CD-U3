// ════════════════════════════════════════════════════════════════
// JENKINSFILE — Pipeline CD Final (Auto-Build & Deploy)
// Proyecto: EFEFIC-FDVP20261-CI-CD-U3
// ════════════════════════════════════════════════════════════════

pipeline {
    agent any

    environment {
        K8S_NAMESPACE = "devops-lab"
        APP_NAME      = "devops-app"
        MCP_URL       = "http://mcp-k8s-server:3100/mcp"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Inicio') {
            steps {
                echo "======================================="
                echo " CD Pipeline #${env.BUILD_NUMBER}"
                echo " Proyecto: EFEFIC-FDVP20261-CI-CD-U3"
                echo "======================================="
                cleanWs()
                checkout scm
            }
        }

        // ── FIX: Usar """ (dobles) para que Groovy expanda ${env.DOCKER_IMAGE}
        //         después de asignarlo en el bloque script {}
        stage('Preparar Imagen Docker') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    script {
                        env.DOCKER_IMAGE = "${DOCKER_USER}/${APP_NAME}"
                    }
                    sh """
                        echo "Iniciando sesión segura en Docker Hub..."
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin

                        echo "Buscando imagen \${DOCKER_IMAGE}:latest en Docker Hub..."

                        if docker pull \${DOCKER_IMAGE}:latest; then
                            echo "✅ Imagen encontrada. Lista para desplegar."
                        else
                            echo "⚠️ Imagen no encontrada. Construyendo desde Dockerfile..."
                            docker build -t \${DOCKER_IMAGE}:latest .
                            echo "🚀 Subiendo imagen a Docker Hub..."
                            docker push \${DOCKER_IMAGE}:latest
                        fi
                    """
                }
            }
        }

        stage('Preparar Kubernetes') {
            steps {
                sh """
                    kubectl cluster-info
                    kubectl get namespace ${K8S_NAMESPACE} 2>/dev/null || \
                        kubectl create namespace ${K8S_NAMESPACE}
                    echo "Namespace ${K8S_NAMESPACE} listo."
                """
            }
        }

        stage('Crear Secrets K8s') {
            when {
                expression {
                    sh(returnStatus: true,
                       script: "kubectl get secret grafana-credentials -n ${K8S_NAMESPACE} 2>/dev/null") != 0
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'grafana-credentials',
                    usernameVariable: 'G_USER',
                    passwordVariable: 'G_PASS'
                )]) {
                    sh """
                        kubectl create secret generic grafana-credentials \
                          --from-literal=admin-user=\${G_USER} \
                          --from-literal=admin-password=\${G_PASS} \
                          -n ${K8S_NAMESPACE} || true
                        echo "Secret grafana-credentials verificado."
                    """
                }
            }
        }

        stage('Desplegar Aplicacion') {
            steps {
                sh """
                    echo "Aplicando configuraciones y desplegando..."
                    kubectl apply -f k8s/configmap.yaml  -n ${K8S_NAMESPACE}
                    kubectl apply -f k8s/deployment.yaml -n ${K8S_NAMESPACE}
                    kubectl apply -f k8s/service.yaml    -n ${K8S_NAMESPACE}

                    kubectl set image deployment/${APP_NAME} \
                        ${APP_NAME}=\${DOCKER_IMAGE}:latest \
                        -n ${K8S_NAMESPACE}

                    kubectl rollout restart deployment/${APP_NAME} -n ${K8S_NAMESPACE}

                    echo "Esperando a que los Pods estén listos..."
                    kubectl rollout status deployment/${APP_NAME} \
                        -n ${K8S_NAMESPACE} --timeout=180s

                    kubectl get pods -n ${K8S_NAMESPACE} -l app=${APP_NAME}
                """
            }
        }

        // ── FIX: Eliminado python3 -m json.tool (no disponible en el pod Jenkins)
        //         La respuesta JSON del MCP se imprime directamente — es legible
        //         y válida como evidencia para el informe técnico.
        stage('Smoke Test & MCP') {
            steps {
                sh """
                    echo "=== Verificación Final ==="
                    sleep 10

                    echo "--- Health Check ---"
                    kubectl run smoke-${BUILD_NUMBER} \
                        --image=curlimages/curl:latest \
                        --restart=Never --rm -it \
                        -n ${K8S_NAMESPACE} \
                        -- curl -sf http://${APP_NAME}:8080/actuator/health \
                        && echo "✅ HEALTH CHECK OK" || echo "⚠️ App iniciando aún..."

                    echo ""
                    echo "--- MCP: get_pods ---"
                    curl -sf -X POST \${MCP_URL} \
                      -H 'Content-Type: application/json' \
                      -d '{"jsonrpc":"2.0","id":1,"method":"tools/call","params":{"name":"get_pods","arguments":{"namespace":"${K8S_NAMESPACE}","label":"app=${APP_NAME}"}}}' \
                      || echo "⚠️ MCP no responde — verificar pod mcp-k8s-server"

                    echo ""
                    echo "--- MCP: rollout_status ---"
                    curl -sf -X POST \${MCP_URL} \
                      -H 'Content-Type: application/json' \
                      -d '{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"rollout_status","arguments":{"deployment":"${APP_NAME}","namespace":"${K8S_NAMESPACE}"}}}' \
                      || true

                    echo ""
                    echo "=== Estado final del clúster ==="
                    kubectl get all -n ${K8S_NAMESPACE}
                """
            }
        }
    }

    post {
        success {
            echo """
🚀 DESPLIEGUE EXITOSO
Accesos locales (NodePort):
  App:         http://localhost:30080
  Jenkins:     http://localhost:30090
  SonarQube:   http://localhost:30092
  Prometheus:  http://localhost:30093
  Grafana:     http://localhost:30094
            """
        }
        failure {
            echo "❌ El pipeline falló. Revisando logs..."
            sh "kubectl get pods -n ${K8S_NAMESPACE} -l app=${APP_NAME} || true"
            sh "kubectl describe deployment ${APP_NAME} -n ${K8S_NAMESPACE} || true"
            sh "kubectl logs -l app=${APP_NAME} -n ${K8S_NAMESPACE} --tail=30 || true"
        }
    }
}